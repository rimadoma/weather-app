{
  "users": [
    {
      "name": "weather",
      "password": "weather",
      "tags": ["administrator"]
    }
  ],
  "vhosts": [
    { "name": "/" }
  ],
  "permissions": [
    {
      "user": "weather",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "exchanges": [
    {
      "name": "stations",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "metoffice",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "stations.temperature.queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "stations.wind.queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "stations.registration.queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "weather.warnings.queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "stations",
      "vhost": "/",
      "destination": "stations.temperature.queue",
      "destination_type": "queue",
      "routing_key": "stations.temperature",
      "arguments": {}
    },
    {
      "source": "stations",
      "vhost": "/",
      "destination": "stations.wind.queue",
      "destination_type": "queue",
      "routing_key": "stations.wind",
      "arguments": {}
    },
    {
      "source": "stations",
      "vhost": "/",
      "destination": "stations.registration.queue",
      "destination_type": "queue",
      "routing_key": "stations.registration",
      "arguments": {}
    },
    {
      "source": "metoffice",
      "vhost": "/",
      "destination": "weather.warnings.queue",
      "destination_type": "queue",
      "routing_key": "weather.warnings",
      "arguments": {}
    }
  ]
}
